# Copy this file to `.env` and change values for your local environment.
# `.env` is gitignored and should not be committed.

POSTGRES_DB=agentnet
POSTGRES_USER=agentnet
POSTGRES_PASSWORD=change_me_local
DATABASE_URL=postgresql://agentnet:change_me_local@postgres:5432/agentnet
THREAD_RETENTION_DAYS=30

THREAD_SOFT_LIMIT_TOKENS=50000
THREAD_HARD_LIMIT_TOKENS=60000
THREAD_KEEP_TAIL_MESSAGES=24
THREAD_COMPACTION_EVENT_ENABLED=true
THREAD_COMPACTION_EVENT_COOLDOWN_SECONDS=120
TOKEN_ESTIMATE_CHARS_PER_TOKEN=4
