# Novita (OpenAI-compatible) config
NOVITA_API_KEY=<YOUR_NOVITA_API_KEY>
NOVITA_BASE_URL=https://api.novita.ai/openai
NOVITA_MODEL=zai-org/glm-5
NOVITA_TEMPERATURE=0.7
NOVITA_MAX_TOKENS=256
LOG_TEXT_MAX_CHARS=700

# AgentNet transport
NATS_URL=nats://agentnet_secret_token@localhost:4222
DEV_AUTH=false
DEV_AUTH_KEY_DIR=.keys

# Generic LLM providers for mesh skeleton
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Tool APIs (used by /tools)
RSC_BASE_URL=https://rest.datafeeds.rolling-insights.com/api/v1
RSC_TOKEN=<YOUR_RSC_TOKEN>
ODDS_API_KEY=<YOUR_ODDS_API_KEY>
PERPLEXITY_API_KEY=<YOUR_PERPLEXITY_API_KEY>

# Demo agent IDs
AGENT_A_ID=agent_novita_a
AGENT_B_ID=agent_novita_b
AGENT_C_ID=agent_novita_c

# Demo usernames (routing)
AGENT_A_USERNAME=agent_novita_a
AGENT_B_USERNAME=agent_novita_b
AGENT_C_USERNAME=agent_novita_c
TARGET_B_USERNAME=agent_novita_b
TARGET_C_USERNAME=agent_novita_c

# Demo behavior
DEMO_GOAL="Design a robust architecture for an AI weather assistant."
DEMO_TURNS=4
DEMO_THREAD_ID=
REQUEST_TIMEOUT_SECONDS=90
REPLY_TTL_MS=30000
MESH_TOOL_LOOP_MAX_STEPS=2
MESH_PLANNER_MAX_TOKENS=1200
MESH_FINAL_MAX_TOKENS=1200
MESH_LLM_TIMEOUT_SECONDS=45
MESH_OPENAI_API_MODE=auto
MESH_WORK_TIMEOUT_SECONDS=240
MESH_AGENT1_ORCHESTRATE=false
MESH_AGENT1_PEERS=mesh_agent_2,mesh_agent_3
MESH_AGENT1_DEBATE_ROUNDS=2
MESH_AGENT1_PEER_TIMEOUT_SECONDS=45
MESH_AGENT1_PEER_RETRIES=1
MESH_AGENT1_KICKOFF_TOOLS=get_daily_schedule,get_pregame_context

# Optional per-responder prompt overrides for the 3-agent demo
AGENT_B_SYSTEM_PROMPT="You are Agent B. Give practical and technically correct replies in plain text."
AGENT_C_SYSTEM_PROMPT="You are Agent C. Give concise, opinionated architecture feedback in plain text."
