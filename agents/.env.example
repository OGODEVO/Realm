# Novita (OpenAI-compatible) config
NOVITA_API_KEY=<YOUR_NOVITA_API_KEY>
NOVITA_BASE_URL=https://api.novita.ai/openai
NOVITA_MODEL=zai-org/glm-5
NOVITA_TEMPERATURE=0.7
NOVITA_MAX_TOKENS=256
LOG_TEXT_MAX_CHARS=700

# AgentNet transport
NATS_URL=nats://agentnet_secret_token@localhost:4222

# Demo agent IDs
AGENT_A_ID=agent_novita_a
AGENT_B_ID=agent_novita_b

# Demo usernames (routing)
AGENT_A_USERNAME=agent_novita_a
AGENT_B_USERNAME=agent_novita_b
TARGET_USERNAME=agent_novita_b

# Demo behavior
DEMO_GOAL="Design a robust architecture for an AI weather assistant."
DEMO_TURNS=4
REQUEST_TIMEOUT_SECONDS=90
REPLY_TTL_MS=30000
